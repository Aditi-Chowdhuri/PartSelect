# Environment variables — never commit real keys
.env
.env.local
.env.*.local

# Dependencies
node_modules/
__pycache__/
*.pyc
.venv/
venv/

# Build output
.next/
out/
dist/

# Next.js auto-generated
next-env.d.ts

# TypeScript build cache
*.tsbuildinfo

# FAISS binary index (regenerate with embed_and_index.py)
backend/app/data/*.bin

# Raw scraped data (regenerate with scraper scripts)
scraper/data/

# Stray data dir written by build scripts run from project root (root-level only)
/data/

# Downloaded PartSelect XML sitemaps (large, not tracked)
xml/

# Claude Code local settings
.claude/

# Misc
.DS_Store
*.log
